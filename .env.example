EXPO_PUBLIC_BD_BACKEND_URL=https://your-backend.example.com
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
AI_GATEWAY_RESEARCH_MODEL=google/gemini-2.5-flash-lite
AI_GATEWAY_ANALYSIS_MODEL=google/gemini-2.5-flash-lite

# MVP/dev only: direct mobile calls expose the key in the app bundle.
EXPO_PUBLIC_AI_GATEWAY_DIRECT=0
EXPO_PUBLIC_AI_GATEWAY_API_KEY=your_public_dev_gateway_key
EXPO_PUBLIC_AI_GATEWAY_RESEARCH_MODEL=google/gemini-2.5-flash-lite
EXPO_PUBLIC_AI_GATEWAY_ANALYSIS_MODEL=google/gemini-2.5-flash-lite

# Supabase public mobile client values. Never put a service_role key in Expo.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Local Expo preview only: starter, plus, or pro. Leave empty in production.
EXPO_PUBLIC_PREVIEW_SUBSCRIPTION_PLAN=

# OAuth redirects to allow in Supabase Auth URL Configuration:
# bullshitdetector://
# exp://<your-dev-url>/--/
# https://ztsijmguraddqiuocylk.supabase.co/auth/v1/callback stays provider-side callback.
